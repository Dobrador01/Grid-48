{
  "name": "grid48-engine",
  "version": "1.0.0",
  "description": "Grid 48 Local Engine",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate:sqlite --schema=./src/db/schema.ts --out=./src/db/migrations",
    "db:migrate": "node dist/db/migrate.js",
    "db:migrate:dev": "tsx src/db/migrate.ts",
    "proto:generate": "buf generate ../proto --path ../proto/grid48 --template buf.gen.yaml"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.8.0",
    "@hono/node-server": "^1.11.0",
    "@hono/node-ws": "^1.0.4",
    "better-sqlite3": "^9.6.0",
    "convex": "^1.12.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "hono": "^4.2.7",
    "node-cron": "^3.0.3",
    "serialport": "^12.0.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^1.10.1",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.12.11",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.5.10",
    "drizzle-kit": "^0.20.17",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
